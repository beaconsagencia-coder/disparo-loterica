# ---- Frontend (Vite) ----
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# ---- Edge Functions (Supabase secrets) ----
# Configure via: supabase secrets set NOME=valor
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY já são injetados automaticamente nas functions.
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-global-api-key
# Token compartilhado para validar chamadas do Cron -> dispatcher
DISPATCHER_CRON_SECRET=troque-este-token
# Chave da API do Google Gemini — para o SDR com IA. Pegue em aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
